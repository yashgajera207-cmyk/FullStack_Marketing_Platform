
---
const {
  analytics = []
} = Astro.props;

/* =========================
   CREATE LABELS
========================= */

const labels =
  analytics.map(
    (item) =>
      `${item.month} ${item.year}`
  );

/* =========================
   CREATE SALES DATA
========================= */

const salesData =
  analytics.map(
    (item) =>
      Number(
        item.sales || 0
      )
  );
---

<div
  class="rounded-[32px] border border-white/10 bg-white/[0.04] p-8"
>

  <!-- HEADER -->

  <div
    class="mb-8"
  >

    <h2
      class="text-3xl font-black text-white"
    >
      Sales Performance
    </h2>

    <p
      class="mt-2 text-white/50"
    >
      Real-time sales analytics
    </p>

  </div>

  <!-- CHART -->

  <div
    class="h-[400px]"
  >

    <canvas
      id="salesChart"
    ></canvas>

  </div>

</div>

<script
  type="module"
  define:vars={{
    labels,
    salesData
  }}
>

import {
  Chart,
  BarController,
  BarElement,
  CategoryScale,
  LinearScale,
  Tooltip,
  Legend
}
from "https://cdn.jsdelivr.net/npm/chart.js@4.4.1/+esm";

Chart.register(
  BarController,
  BarElement,
  CategoryScale,
  LinearScale,
  Tooltip,
  Legend
);

const canvas =
  document.getElementById(
    "salesChart"
  );

if (canvas) {

  new Chart(
    canvas,
    {

      type: "bar",

      data: {

        labels,

        datasets: [{

          label: "Sales",

          data: salesData,

          backgroundColor:
            "#06b6d4",

          borderRadius: 16,

          borderSkipped: false,

          barThickness: 60,

          maxBarThickness: 70

        }]

      },

      options: {

        responsive: true,

        maintainAspectRatio: false,

        animation: {

          duration: 1500

        },

        plugins: {

          legend: {

            position: "top",

            labels: {

              color: "#ffffff",

              font: {

                size: 14,

                weight: "bold"

              }

            }

          },

          tooltip: {

            backgroundColor:
              "#111827",

            titleColor:
              "#ffffff",

            bodyColor:
              "#d1d5db",

            borderColor:
              "#06b6d4",

            borderWidth: 1

          }

        },

        scales: {

          x: {

            ticks: {

              color: "#9ca3af",

              font: {

                size: 13

              }

            },

            grid: {

              display: false

            }

          },

          y: {

            beginAtZero: true,

            ticks: {

              color: "#9ca3af",

              font: {

                size: 13

              }

            },

            grid: {

              color:
                "rgba(255,255,255,0.05)"

            }

          }

        }

      }

    }
  );

}

</script>
