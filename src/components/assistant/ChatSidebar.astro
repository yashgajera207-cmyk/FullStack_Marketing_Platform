>

  <div class="border-b border-white/10 p-5">

    <button
      id="newChatBtn"
      class="group flex w-full items-center justify-center gap-2 rounded-2xl bg-gradient-to-r from-lime-400 to-lime-300 px-4 py-3 font-semibold text-black shadow-lg transition-all duration-300 hover:scale-[1.02] hover:shadow-lime-500/30"
    >
      <span class="text-lg transition-transform group-hover:rotate-90">
        +
      </span>

      <span>
        New Chat
      </span>
    </button>

  </div>

  <div
    class="border-b border-white/10 p-4"
  >
    <h3
      class="text-xs uppercase tracking-[0.2em] text-white/40"
