---

---

<div
  id="newChatModal"
  class="fixed inset-0 z-[999] hidden items-center justify-center bg-black/70 backdrop-blur-sm"
>

  <div
    class="w-full max-w-md rounded-3xl border border-white/10 bg-[#111827] p-6 shadow-2xl"
  >


<div
  class="mb-5 flex items-center gap-3"
>

  <div
    class="flex h-12 w-12 items-center justify-center rounded-2xl bg-lime-400 font-bold text-black"
  >
    AI
  </div>

  <div>

    <h2
      class="text-lg font-semibold text-white"
    >
      Create New Chat
    </h2>

    <p
      class="text-sm text-white/50"
    >
      Give your conversation a title
    </p>

  </div>

</div>

<input
  id="chatTitleInput"
  type="text"
  placeholder="e.g. Marketing Strategy"
  class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white outline-none transition-all focus:border-lime-400"
/>

<div
  class="mt-5 flex justify-end gap-3"
>

  <button
    id="cancelChatBtn"
    type="button"
    class="rounded-xl border border-white/10 px-4 py-2 text-white/70 transition hover:bg-white/5"
  >
    Cancel
  </button>

  <button
    id="createChatBtn"
    type="button"
    class="rounded-xl bg-lime-400 px-5 py-2 font-semibold text-black transition hover:scale-105"
  >
    Create Chat
  </button>

</div>


  </div>

</div>
