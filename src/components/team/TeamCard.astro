---
interface Props {
  member: any;
  strapiUrl: string;
}

const {
  member,
  strapiUrl,
} = Astro.props;

const image =
  member?.image?.url
    ? `${strapiUrl}${member.image.url}`
    : "https://placehold.co/600x600/111827/FFFFFF?text=Member";
---

<div
  class="group overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] backdrop-blur-xl transition-all duration-300 hover:-translate-y-1 hover:border-lime-400/40 hover:bg-white/[0.05] hover:shadow-2xl hover:shadow-lime-500/10"
>

  <!-- Image -->

  <div
    class="relative overflow-hidden"
  >

    <img
      src={image}
      alt={member?.name || "Team Member"}
      class="h-72 w-full object-cover transition-all duration-500 group-hover:scale-105"
      loading="lazy"
    />

    <div
      class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"
    ></div>

    <div
      class="absolute bottom-4 left-4"
    >

      <span
        class="rounded-full border border-lime-400/30 bg-lime-400/10 px-3 py-1 text-xs font-medium text-lime-400"
      >
        Team Member
      </span>

    </div>

  </div>

  <!-- Content -->

  <div
    class="space-y-5 p-6"
  >

    <div>

      <h3
        class="truncate text-2xl font-bold text-white"
      >
        {member?.name}
      </h3>

      <p
        class="mt-1 text-sm font-medium text-lime-400"
      >
        {member?.designation}
      </p>

    </div>

    {
      member?.description && (
        <p
          class="line-clamp-3 text-sm leading-relaxed text-white/60"
        >
          {member.description}
        </p>
      )
    }

    <div
      class="space-y-3 border-t border-white/10 pt-4"
    >

      {
        member?.email && (
          <div
            class="flex items-center gap-3 text-sm text-white/70"
          >
            <span>📧</span>
            <span class="truncate">
              {member.email}
            </span>
          </div>
        )
      }

      {
        member?.phone && (
          <div
            class="flex items-center gap-3 text-sm text-white/70"
          >
            <span>📱</span>
            <span>
              {member.phone}
            </span>
          </div>
        )
      }

    </div>

    <!-- Actions -->

    <div
      class="flex gap-3 pt-2"
    >

      {
        member?.email && (
         <button
  class="view-member-btn mt-5 inline-flex w-full justify-center rounded-2xl bg-lime-400 px-4 py-3 font-semibold text-black transition-all duration-300 hover:bg-lime-300"
  data-member={JSON.stringify(member)}
>
  View Details
</button>
        )
      }
{
  member?.whatsapp_link && (
    <a
      href={`https://wa.me/${member.whatsapp_link}`}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 rounded-2xl border border-green-500/20 bg-green-500/10 px-5 py-3 text-sm font-medium text-green-400 transition-all duration-300 hover:border-green-400/40 hover:bg-green-500/20 hover:text-green-300"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="h-5 w-5"
      >
        <path d="M12.04 2C6.53 2 2.06 6.47 2.06 11.98c0 1.77.46 3.5 1.34 5.02L2 22l5.14-1.35a9.93 9.93 0 0 0 4.9 1.25h.01c5.5 0 9.97-4.47 9.97-9.98S17.55 2 12.04 2Zm5.83 14.09c-.25.7-1.46 1.34-2.01 1.42-.52.08-1.18.12-1.91-.11-.44-.14-1.01-.33-1.75-.65-3.08-1.33-5.08-4.45-5.24-4.66-.16-.21-1.25-1.67-1.25-3.18 0-1.51.79-2.25 1.07-2.56.29-.31.62-.39.83-.39.21 0 .42 0 .61.01.19.01.45-.07.71.55.25.61.85 2.11.93 2.27.08.16.13.35.03.56-.1.21-.15.34-.3.52-.15.18-.31.41-.44.55-.15.15-.31.32-.13.62.18.31.81 1.34 1.74 2.17 1.19 1.06 2.19 1.39 2.5 1.54.31.15.49.13.67-.08.18-.21.78-.91.99-1.22.21-.31.42-.26.71-.15.29.1 1.84.87 2.15 1.03.31.16.52.23.6.36.08.13.08.75-.17 1.45Z"/>
      </svg>

      <span>
        WhatsApp
      </span>
    </a>
  )
}

    </div>

  </div>

</div>