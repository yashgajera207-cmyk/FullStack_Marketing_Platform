---

<div
  id="memberModal"
  class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 p-4 backdrop-blur-md"
>

  <div
    class="relative max-h-[90vh] w-full max-w-4xl overflow-hidden rounded-[32px] border border-white/10 bg-[#0D1117] shadow-2xl"
  >

    <!-- Close Button -->

    <button
      id="closeMemberModal"
      class="absolute right-5 top-5 z-50 flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-xl text-white/70 transition-all duration-300 hover:bg-red-500/20 hover:text-red-400"
    >
      ✕
    </button>

    <!-- Dynamic Content -->

    <div
      id="memberModalContent"
      class="overflow-y-auto"
    >
    </div>

  </div>

</div>