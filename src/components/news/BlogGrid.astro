---
import BlogCard from "./BlogCard.astro";

interface Props {
  blogs: any[];
  strapiUrl: string;
}

const {
  blogs,
  strapiUrl
} = Astro.props;
---

<div
  id="blogGrid"
  class="grid gap-8 md:grid-cols-2 xl:grid-cols-3"
>

  {
    blogs.map(
      (blog) => (
        <BlogCard
          blog={blog}
          strapiUrl={strapiUrl}
        />
      )
    )
  }

</div>