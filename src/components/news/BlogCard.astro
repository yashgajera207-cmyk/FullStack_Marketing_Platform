---
interface Props {
  blog: any;
  strapiUrl: string;
}

const {
  blog,
  strapiUrl
} = Astro.props;

const item =
  blog.attributes || blog;

const image =
  item?.featured_image?.url ||
  item?.featured_image?.data?.attributes?.url;

const category =
  item?.category?.name ||
  item?.category?.data?.attributes?.name ||
  "";

const categorySlug =
  item?.category?.slug ||
  item?.category?.data?.attributes?.slug ||
  "";
---

<article
  class="blog-card overflow-hidden rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl"
  data-category={categorySlug}
>

  <img
    src={
      image
        ? image.startsWith("http")
          ? image
          : strapiUrl + image
        : "https://placehold.co/800x500?text=News"
    }
    alt={item.title}
    class="h-56 w-full object-cover"
  />

  <div
    class="p-6"
  >

    <span
      class="rounded-full bg-lime-400/10 px-3 py-1 text-xs font-semibold text-lime-400"
    >
      {category}
    </span>

    <h2
      class="mt-4 line-clamp-2 text-2xl font-bold text-white"
    >
      {item.title}
    </h2>

    <p
      class="mt-3 line-clamp-3 text-white/60"
    >
      {item.excerpt}
    </p>

    <a
      href={`/dashboard/news/${item.slug}`}
      class="mt-6 inline-flex font-semibold text-lime-400"
    >
      Read More →
    </a>

  </div>

</article>