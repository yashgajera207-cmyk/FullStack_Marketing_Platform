<script type="module">

/* ===================================
   GLOBAL FLAGS
=================================== */

let dropdownInitialized =
  false;

let cachedProfile =
  null;

/* ===================================
   ACTIVE NAVBAR
=================================== */

function updateActiveNav() {

  const currentPath =
    window.location.pathname;

  const navLinks =
    document.querySelectorAll(
      "[data-nav-link]"
    );

  navLinks.forEach(
    (link) => {

      link.classList.remove(
        "text-lime-400"
      );

      if (
        link.getAttribute(
          "href"
        ) === currentPath
      ) {

        link.classList.add(
          "text-lime-400"
        );

      }

    }
  );

}

/* ===================================
   RENDER PROFILE
=================================== */

function renderProfile(
  user
) {

  if (!user)
    return;

  /* NAVBAR */

  const profileName =
    document.getElementById(
      "profileName"
    );

  const profileEmail =
    document.getElementById(
      "profileEmail"
    );

  if (profileName) {

    profileName.textContent =
      user.business_name ||
      "Business";

  }

  if (profileEmail) {

    profileEmail.textContent =
      user.owner_name ||
      "Owner";

  }

  /* DROPDOWN */

  const businessName =
    document.getElementById(
      "businessName"
    );

  const dropdownName =
    document.getElementById(
      "dropdownName"
    );

  const dropdownEmail =
    document.getElementById(
      "dropdownEmail"
    );

  const phone =
    document.getElementById(
      "phone"
    );

  const gst =
    document.getElementById(
      "gst"
    );

  const address =
    document.getElementById(
      "address"
    );

  if (businessName) {

    businessName.textContent =
      user.business_name ||
      "-";

  }

  if (dropdownName) {

    dropdownName.textContent =
      user.owner_name ||
      "-";

  }

  if (dropdownEmail) {

    dropdownEmail.textContent =
      user.email ||
      "-";

  }

  if (phone) {

    phone.textContent =
      user.phone ||
      "-";

  }

  if (gst) {

    gst.textContent =
      user.gst_number ||
      "-";

  }

  if (address) {

    address.textContent =
      user.address ||
      "-";

  }

  /* LOGOS */

  const profileAvatar =
    document.getElementById(
      "profileAvatar"
    );

  const dropdownAvatar =
    document.getElementById(
      "dropdownAvatar"
    );

  if (
    user.logo_url &&
    user.logo_url.trim() !== ""
  ) {

    if (profileAvatar) {

      profileAvatar.innerHTML = `
        <img
          src="${user.logo_url}"
          class="h-12 w-12 rounded-xl object-cover"
        />
      `;

    }

    if (dropdownAvatar) {

      dropdownAvatar.innerHTML = `
        <img
          src="${user.logo_url}"
          class="h-full w-full object-cover"
        />
      `;

    }

  }

}

/* ===================================
   LOAD PROFILE
=================================== */

async function loadProfile() {

  try {

    /* USE CACHE */

    if (cachedProfile) {

      renderProfile(
        cachedProfile
      );

      return;

    }

    const response =
      await fetch(
        "/api/business/profile"
      );

    const result =
      await response.json();

    if (
      !result.success
    ) {

      console.error(
        result.message
      );

      return;

    }

    const user =
      result.user;

    /* SAVE CACHE */

    cachedProfile =
      user;

    /* RENDER */

    renderProfile(
      user
    );

  } catch (error) {

    console.error(
      "PROFILE ERROR:",
      error
    );

  }

}

/* ===================================
   DROPDOWN
=================================== */

function initDropdown() {

  if (
    dropdownInitialized
  ) return;

  dropdownInitialized =
    true;

  const profileBtn =
    document.getElementById(
      "profileBtn"
    );

  const dropdown =
    document.getElementById(
      "profileDropdown"
    );

  if (
    !profileBtn ||
    !dropdown
  ) return;

  /* BUTTON */

  profileBtn.addEventListener(
    "click",
    (e) => {

      e.stopPropagation();

      dropdown.classList.toggle(
        "hidden"
      );

    }
  );

  /* OUTSIDE CLICK */

  document.addEventListener(
    "click",
    (e) => {

      if (
        !dropdown.contains(
          e.target
        ) &&
        !profileBtn.contains(
          e.target
        )
      ) {

        dropdown.classList.add(
          "hidden"
        );

      }

    }
  );

}

/* ===================================
   INIT NAVBAR
=================================== */

async function initNavbar() {

  updateActiveNav();

  await loadProfile();

  initDropdown();

}

/* ===================================
   FIRST PAGE LOAD
=================================== */

document.addEventListener(
  "DOMContentLoaded",
  async () => {

    await initNavbar();

  }
);

/* ===================================
   ASTRO SPA NAVIGATION
=================================== */

document.addEventListener(
  "astro:page-load",
  async () => {

    /* WAIT FOR DOM */

    setTimeout(
      async () => {

        updateActiveNav();

        /* RENDER CACHED PROFILE */

        if (
          cachedProfile
        ) {

          renderProfile(
            cachedProfile
          );

        } else {

          await loadProfile();

        }

        initDropdown();

      },
      50
    );

  }
);

</script>





