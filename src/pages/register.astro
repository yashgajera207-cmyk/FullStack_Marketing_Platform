---
import "../styles/global.css";
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />
  <title>Register Business | GrowthPilot</title>
</head>

<body class="min-h-screen bg-[#050816] text-white overflow-x-hidden">

  <!-- Background -->

  <div class="fixed inset-0 -z-10">
    <div class="absolute left-0 top-0 h-[500px] w-[500px] rounded-full bg-lime-400/20 blur-[180px]"></div>


<div class="absolute right-0 top-0 h-[500px] w-[500px] rounded-full bg-cyan-500/20 blur-[180px]"></div>

<div class="absolute bottom-0 left-1/2 h-[400px] w-[400px] rounded-full bg-purple-500/20 blur-[180px]"></div>


  </div>

  <div class="grid min-h-screen lg:grid-cols-2">


<!-- Left -->

<div
  class="hidden lg:flex flex-col justify-center px-12 xl:px-20"
>
  <span
    class="mb-6 inline-flex w-fit rounded-full border border-lime-400/20 bg-lime-400/10 px-5 py-2 text-lime-400"
  >
    🚀 Business Growth Platform
  </span>

  <h1
    class="max-w-xl text-6xl font-black leading-tight"
  >
    Grow Your Business With

    <span
      class="bg-gradient-to-r from-lime-400 via-cyan-400 to-purple-500 bg-clip-text text-transparent"
    >
      AI Intelligence
    </span>
  </h1>

  <p
    class="mt-8 max-w-lg text-xl text-gray-400"
  >
    Manage customers, automate marketing,
    track analytics and scale your company.
  </p>

  <div
    class="mt-12 grid grid-cols-2 gap-6"
  >
    <div
      class="rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl"
    >
      <h3
        class="text-3xl font-bold text-lime-400"
      >
        50K+
      </h3>

      <p class="text-gray-400">
        Businesses
      </p>
    </div>

    <div
      class="rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl"
    >
      <h3
        class="text-3xl font-bold text-cyan-400"
      >
        99.9%
      </h3>

      <p class="text-gray-400">
        Uptime
      </p>
    </div>
  </div>
</div>

<!-- Register Form -->

<div
  class="flex items-center justify-center p-6"
>
  <div
    class="w-full max-w-2xl rounded-[40px] border border-white/10 bg-white/5 p-8 backdrop-blur-2xl md:p-10"
  >

    <div class="mb-8 text-center">
      <h2
        class="text-4xl font-black"
      >
        Business Registration
      </h2>

      <p
        class="mt-3 text-gray-400"
      >
        Create your business account
      </p>
    </div>

    <form
      id="registerForm"
      class="space-y-5"
    >

    <!-- Logo Upload -->
<div>
  <label class="mb-2 block text-sm text-gray-300">
    Business Logo
  </label>

  <input
    id="logo"
    type="file"
    accept="image/png,image/jpeg,image/jpg,image/webp"
    class="w-full rounded-2xl border border-white/10 bg-black/20 p-4"
  />
</div>

<!-- Business Name -->
<input
  id="businessName"
  type="text"
  required
  minlength="3"
  placeholder="Business Name"
  class="w-full rounded-2xl border border-white/10 bg-black/20 p-4"
/>

<!-- Owner Name -->
<input
  id="fullName"
  type="text"
  required
  minlength="3"
  placeholder="Owner Name"
  class="w-full rounded-2xl border border-white/10 bg-black/20 p-4"
/>

<!-- Email -->
<input
  id="email"
  type="email"
  required
  placeholder="Business Email"
  class="w-full rounded-2xl border border-white/10 bg-black/20 p-4"
/>

<!-- Mobile -->
<input
  id="phone"
  type="tel"
  required
  pattern="[6-9]{1}[0-9]{9}"
  maxlength="10"
  placeholder="Mobile Number"
  class="w-full rounded-2xl border border-white/10 bg-black/20 p-4"
/>

<!-- Address -->
<textarea
  id="address"
  rows="3"
  required
  placeholder="Business Address"
  class="w-full rounded-2xl border border-white/10 bg-black/20 p-4"
></textarea>

<!-- GST -->
<input
  id="gst"
  type="text"
  required
  placeholder="GST Number"
  pattern="^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$"
  class="w-full rounded-2xl border border-white/10 bg-black/20 p-4"
/>

      <div class="relative">
        <input
          id="password"
          type="password"
          placeholder="Password"
          required
          minlength="6"
          class="w-full rounded-2xl border border-white/10 bg-black/20 p-4 pr-14 outline-none focus:border-lime-400"
        />

        <button
          type="button"
          id="togglePassword"
          class="absolute right-4 top-1/2 -translate-y-1/2"
        >
          👁️
        </button>
      </div>

      <button
        id="registerBtn"
        type="submit"
        class="w-full rounded-2xl bg-lime-400 py-4 font-bold text-black transition-all duration-500 hover:scale-[1.02]"
      >
        Create Business Account
      </button>

    </form>

    <p
      class="mt-8 text-center text-gray-400"
    >
      Already have an account?

      <a
        href="/login"
        class="font-semibold text-lime-400 hover:underline"
      >
        Login
      </a>
    </p>

  </div>
</div>


  </div>

<script>
document.addEventListener(
  "DOMContentLoaded",
  () => {

    const form =
      document.getElementById(
        "registerForm"
      );

    const toggle =
      document.getElementById(
        "togglePassword"
      );

    const passwordInput =
      document.getElementById(
        "password"
      );

    const phoneInput =
      document.getElementById(
        "phone"
      );

    const button =
      document.getElementById(
        "registerBtn"
      );

    if (
      !form ||
      !toggle ||
      !passwordInput ||
      !phoneInput
    ) {
      console.error(
        "Required elements not found"
      );
      return;
    }

    /* Numbers Only */

    phoneInput.addEventListener(
      "input",
      (e) => {
        e.target.value =
          e.target.value.replace(
            /[^0-9]/g,
            ""
          );
      }
    );

    /* Show Password */

    toggle.addEventListener(
      "click",
      () => {

        if (
          passwordInput.type ===
          "password"
        ) {

          passwordInput.type =
            "text";

          toggle.textContent =
            "🙈";

        } else {

          passwordInput.type =
            "password";

          toggle.textContent =
            "👁️";
        }
      }
    );

    form.addEventListener(
      "submit",
      async (e) => {

        e.preventDefault();

        const logoFile =
          document.getElementById(
            "logo"
          )?.files?.[0];

        const businessName =
          document.getElementById(
            "businessName"
          ).value.trim();

        const fullName =
          document.getElementById(
            "fullName"
          ).value.trim();

        const email =
          document.getElementById(
            "email"
          ).value.trim();

        const phone =
          document.getElementById(
            "phone"
          ).value.trim();

        const address =
          document.getElementById(
            "address"
          ).value.trim();

        const gst =
          document.getElementById(
            "gst"
          ).value.trim().toUpperCase();

        const password =
          document.getElementById(
            "password"
          ).value;

        /* Email Validation */

        const emailRegex =
          /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        if (
          !emailRegex.test(email)
        ) {
          alert(
            "Please enter a valid email address"
          );
          return;
        }

        /* Mobile Validation */

        if (
          !/^[6-9][0-9]{9}$/.test(
            phone
          )
        ) {
          alert(
            "Enter a valid Indian mobile number"
          );
          return;
        }

        /* GST Validation */

        if (
          gst.length !== 15
        ) {
          alert(
            "Enter a valid GST Number"
          );
          return;
        }

        /* Password Validation */

        if (
          password.length < 6
        ) {
          alert(
            "Password must be at least 6 characters"
          );
          return;
        }

        if (button) {
          button.disabled =
            true;

          button.textContent =
            "Creating Account...";
        }

        try {

          const formData =
            new FormData();

          if (logoFile) {
            formData.append(
              "logo",
              logoFile
            );
          }

          formData.append(
            "businessName",
            businessName
          );

          formData.append(
            "fullName",
            fullName
          );

          formData.append(
            "email",
            email
          );

          formData.append(
            "phone",
            "+91" + phone
          );

          formData.append(
            "address",
            address
          );

          formData.append(
            "gst",
            gst
          );

          formData.append(
            "password",
            password
          );

          const response =
            await fetch(
              "/api/auth/register",
              {
                method: "POST",
                body: formData,
              }
            );

          const result =
            await response.json();

          if (
            !result.success
          ) {

            alert(
              result.message
            );

            if (button) {
              button.disabled =
                false;

              button.textContent =
                "Create Account";
            }

            return;
          }

          alert(
            "Registration Successful 🎉"
          );

          window.location.href =
            "/login";

        } catch (error) {

          console.error(
            "REGISTER ERROR:",
            error
          );

          alert(
            "Registration Failed"
          );

          if (button) {
            button.disabled =
              false;

            button.textContent =
              "Create Account";
          }
        }
      }
    );
  }
);
</script>



</body>
</html>