---
import "../../styles/global.css";

interface Props {
  title?: string;
}

const { title = "GrowthPilot" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body class="bg-[#050816] text-white">
    <slot />
  </body>
</html>