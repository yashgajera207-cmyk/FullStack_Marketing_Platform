---
import "../styles/global.css";
const title = "GrowthPilot - AI Marketing Platform";
const description =
  "Scale your business with AI-powered analytics, automation, and marketing intelligence.";
---

<html lang="en">

<head>

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>
    {title}
  </title>

  <meta
    name="description"
    content={description}
  />

  <meta
    property="og:title"
    content={title}
  />

  <meta
    property="og:description"
    content={description}
  />

  <meta
    name="keywords"
    content="Marketing Dashboard, AI Analytics, SaaS Platform"
  />

  <link
    rel="canonical"
    href="https://your-domain.com"
  />

  <!-- JSON-LD -->

  <script
    type="application/ld+json"
    is:inline
  >

  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "GrowthPilot",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web Browser",
    "description": "Scale your business with AI-powered analytics, automation, and marketing intelligence.",
    "url": "http://localhost:4321"
  }

  </script>

</head>


  <body class="bg-[#050816] text-white overflow-x-hidden">
    <!-- Background Effects -->
    <div class="fixed inset-0 -z-10">
      <div
        class="absolute top-0 left-0 h-[500px] w-[500px] rounded-full bg-lime-400/20 blur-[180px]"
      ></div>

      <div
        class="absolute right-0 top-[200px] h-[500px] w-[500px] rounded-full bg-purple-500/20 blur-[180px]"
      ></div>

      <div
        class="absolute bottom-0 left-1/2 h-[400px] w-[400px] rounded-full bg-cyan-500/20 blur-[160px]"
      ></div>
    </div>

    <!-- Navbar -->
    <header
      class="sticky top-0 z-50 border-b border-white/10 backdrop-blur-xl"
    >
      <div
        class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5"
      >
        <a
          href="/"
          class="text-2xl font-bold tracking-wide"
        >
          GrowthPilot
        </a>



        <div class="flex gap-4">
          <a
            href="/login"
            class="rounded-xl border border-white/20 px-5 py-2 transition hover:border-lime-400"
          >
            Login
          </a>

          <a
            href="/register"
            class="rounded-xl bg-lime-400 px-5 py-2 font-semibold text-black transition hover:scale-105"
          >
            Register
          </a>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <section class="relative">
      <div
        class="mx-auto flex min-h-screen max-w-7xl flex-col items-center justify-center px-6 text-center"
      >
        <div
          class="mb-8 rounded-full border border-lime-400/20 bg-lime-400/10 px-5 py-2 text-sm text-lime-400"
        >
          🚀 AI Powered Marketing Platform
        </div>

        <h1
          class="max-w-5xl text-5xl font-bold leading-tight md:text-7xl"
        >
          Grow Faster With
          <span
            class="bg-gradient-to-r from-lime-400 via-green-300 to-cyan-400 bg-clip-text text-transparent"
          >
            AI Marketing Intelligence
          </span>
        </h1>

        <p
          class="mt-8 max-w-2xl text-lg text-gray-400 md:text-xl"
        >
          Analytics, automation, team collaboration, content generation,
          real-time insights, and AI-powered growth tools in one platform.
        </p>

        <div
          class="mt-10 flex flex-col gap-4 sm:flex-row"
        >
          <a
            href="/register"
            class="group rounded-2xl bg-lime-400 px-8 py-4 font-bold text-black transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_60px_rgba(185,255,102,.45)]"
          >
            Start Free Trial
          </a>

          <a
            href="/login"
            class="rounded-2xl border border-white/20 px-8 py-4 transition-all duration-300 hover:border-lime-400 hover:bg-white/5"
          >
            Login
          </a>
        </div>

        <!-- Stats -->
        <div
          class="mt-16 grid w-full max-w-4xl grid-cols-2 gap-6 md:grid-cols-4"
        >
          <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
            <h3 class="text-3xl font-bold text-lime-400">50K+</h3>
            <p class="mt-2 text-gray-400">Users</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
            <h3 class="text-3xl font-bold text-lime-400">99.9%</h3>
            <p class="mt-2 text-gray-400">Uptime</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
            <h3 class="text-3xl font-bold text-lime-400">120+</h3>
            <p class="mt-2 text-gray-400">Countries</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
            <h3 class="text-3xl font-bold text-lime-400">4.9★</h3>
            <p class="mt-2 text-gray-400">Rating</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Dashboard Preview -->
    <section class="pb-32">
      <div class="mx-auto max-w-7xl px-6">
        <div
          class="rounded-[32px] border border-white/10 bg-white/5 p-8 backdrop-blur-xl"
        >
          <div class="mb-8 flex gap-3">
            <div class="h-3 w-3 rounded-full bg-red-500"></div>
            <div class="h-3 w-3 rounded-full bg-yellow-500"></div>
            <div class="h-3 w-3 rounded-full bg-green-500"></div>
          </div>

          <div class="grid gap-6 lg:grid-cols-4">
            <div
              class="rounded-3xl bg-gradient-to-br from-lime-400/20 to-transparent p-6 transition duration-300 hover:-translate-y-2"
            >
              <h4 class="text-gray-400">Revenue</h4>
              <p class="mt-3 text-4xl font-bold">$48.2K</p>
            </div>

            <div
              class="rounded-3xl bg-gradient-to-br from-purple-500/20 to-transparent p-6 transition duration-300 hover:-translate-y-2"
            >
              <h4 class="text-gray-400">Visitors</h4>
              <p class="mt-3 text-4xl font-bold">128K</p>
            </div>

            <div
              class="rounded-3xl bg-gradient-to-br from-cyan-500/20 to-transparent p-6 transition duration-300 hover:-translate-y-2"
            >
              <h4 class="text-gray-400">Conversion</h4>
              <p class="mt-3 text-4xl font-bold">18%</p>
            </div>

            <div
              class="rounded-3xl bg-gradient-to-br from-pink-500/20 to-transparent p-6 transition duration-300 hover:-translate-y-2"
            >
              <h4 class="text-gray-400">Growth</h4>
              <p class="mt-3 text-4xl font-bold">+76%</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </body>
</html>